# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/yts?retryWrites=true&w=majority&appName=yts-main

# JWT secret for signing tokens (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your-random-64-byte-hex-secret-here

# Environment (development | production)
NODE_ENV=development
